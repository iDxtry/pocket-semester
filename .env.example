# Development AI adapter. Keep the real value only in .env.local or your host's environment settings.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite
AI_PROVIDER=gemini

# Build Week production adapter. Leave AI_PROVIDER=gemini for local development until
# OpenAI credits are available, then configure these server-only values in Vercel and set
# AI_PROVIDER=openai. Never commit a real key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Neon is the only hosted service required for private accounts.
# The app owns password hashing and sessions; never commit a real database URL.
DATABASE_URL=
