# Development AI adapter. Keep the real value only in .env.local or your host's environment settings.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite
AI_PROVIDER=gemini

# Optional OpenAI adapter for accounts with separate API billing. Build Week Codex credits
# do not include API usage. Never claim this is live unless a verified response succeeds.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Neon is the only hosted service required for private accounts.
# The app owns password hashing and sessions; never commit a real database URL.
DATABASE_URL=
